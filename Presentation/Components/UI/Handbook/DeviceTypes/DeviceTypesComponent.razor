@using Domain.Entities
@using Domain.Filters
@using Domain.ValueObjects.Handbook
@using Presentation.Components.UI.Handbook.HandbookDataTable
@using Presentation.Components.UI.Handbook.ModalWondowComponents
@using Presentation.Components.UI.Shared.ModalWindows
@using Presentation.Utils.Enums
@using Presentation.Utils.Services.DeviceTypes

@if(isLoading)
{
    
}
else
{
    <Modal @ref=@modal IsVerticallyCentered=true />

    <DataTableView @ref=@table Items=@(deviceTypes.Select(dt => new TableItem(dt)).ToList()) LoadMoreItems="@LoadMoreDeviceTypes"
        OnItemClick="@OnDeviceTypeRowClick" OnItemDelete="@OnDeviceTypeRowButtonDeleteClick" OnItemUpdate="@OnDeviceTypeRowButtonUpdateClick"/>   
}

@code {
    [Inject]
    private IDeviceTypeService deviceTypeService { get; set; } = null!;

    private DataTableView table = default!;

    private Modal modal = default!;

    private bool isLoading = true;

    private int currentPage = 0;

    private DeviceTypeFilter deviceTypeFilter = new();

    private List<DeviceType> deviceTypes = new();

    protected override async Task OnInitializedAsync()
    {
        deviceTypes = await deviceTypeService.GetDeviceTypesAsync(0, new());
        isLoading = false;
    }

    #region buttons click methods

    private async Task LoadMoreDeviceTypes()
    {
        var nextDeviceTypes = await deviceTypeService.GetDeviceTypesAsync(currentPage + 1, deviceTypeFilter);
        if (nextDeviceTypes.Count > 0)
        {
            currentPage++;
            deviceTypes.AddRange(nextDeviceTypes);
            StateHasChanged();
        }
    }

    private async Task OnDeviceTypeRowClick(TableItem tableItem)
    {
        await ShowDeviceTypeModal(tableItem, FormModeEnum.ViewOnly);
    }

    private async Task OnDeviceTypeRowButtonUpdateClick(TableItem tableItem)
    {
        await ShowDeviceTypeModal(tableItem, FormModeEnum.Edit);
    }

    private async Task OnDeviceTypeRowButtonDeleteClick(TableItem tableItem)
    {
        var parameters = new Dictionary<string, object>();
        parameters.Add("EntityId", tableItem.Id);
        parameters.Add("DeleteMethod", EventCallback.Factory.Create<Guid>(this, DeleteDeviceType));
        parameters.Add("HideModal", EventCallback.Factory.Create(this, async () => await modal.HideAsync()));

        modal.Size = ModalSize.Small;
        await modal.ShowAsync<DeleteEntity>(title: $"Удалить {tableItem.Name.Value}?", parameters: parameters);
    }

    private async Task ShowDeviceTypeModal(TableItem tableItem, FormModeEnum mode)
    {
        DeviceType deviceType;

        if (tableItem != null)
        {
            deviceType = new DeviceType()
            {
                Id = tableItem.Id,
                Name = tableItem.Name,
                Description = tableItem.Description,
                CreatedAt = tableItem.CreatedAt,
                UpdatedAt = tableItem.UpdatedAt
            };
        }
        else
        {
            deviceType = new DeviceType
            {
                Id = default,
                Name = new Name("Новый тип устройства")
            };
        }

        var parameters = new Dictionary<string, object>();
        parameters.Add("Mode", mode);
        parameters.Add("HideModal", EventCallback.Factory.Create(this, async () => await modal.HideAsync()));
        parameters.Add("Delete", EventCallback.Factory.Create<Guid>(this, DeleteDeviceType));

        if (mode == FormModeEnum.ViewOnly || mode == FormModeEnum.Edit)
            parameters.Add("ApplyCommand", EventCallback.Factory.Create<(Guid, string, string)>(this, UpdateDeviceType));
        else
            parameters.Add("ApplyCommand", EventCallback.Factory.Create<(Guid, string, string)>(this, CreateDeviceType));

        parameters.Add("Entity", deviceType);

        modal.Size = ModalSize.Large;
        await modal.ShowAsync<HandbookEntityModalWindowContent>(title: $"{deviceType.Name.Value}", parameters: parameters);
    }

    #endregion

    #region commands to db

    private async Task DeleteDeviceType(Guid deviceTypeId)
    {
        if (await deviceTypeService.DeleteDeviceType(deviceTypeId))
        {
            var removingDeviceTypeEntity = deviceTypes.FirstOrDefault(dt => dt.Id == deviceTypeId);
            if (removingDeviceTypeEntity != null)
            {
                deviceTypes.Remove(removingDeviceTypeEntity);
                StateHasChanged();
                await table.grid.RefreshDataAsync();
            }
            await modal.HideAsync();
        }
    }

    private async Task UpdateDeviceType((Guid, string, string) deviceTypeData)
    {
        if (await deviceTypeService.UpdateDeviceType(deviceTypeData.Item1, deviceTypeData.Item2, deviceTypeData.Item3))
        {
            var updatedDeviceType = deviceTypes.FirstOrDefault(dt => dt.Id == deviceTypeData.Item1);
            if (updatedDeviceType != null)
            {
                updatedDeviceType.Name = new Name(deviceTypeData.Item2);
                updatedDeviceType.Description = new Description(deviceTypeData.Item3);

                StateHasChanged();
                await table.grid.RefreshDataAsync();
            }
            await modal.HideAsync();
        }
    }

    private async Task CreateDeviceType((Guid, string, string) deviceTypeData)
    {
        if (await deviceTypeService.CreateDeviceType(deviceTypeData.Item2, deviceTypeData.Item3) != default)
        {
            await modal.HideAsync();
        }
    }

    #endregion

    #region public methods

    public async Task ShowCreateModal()
    {
        await ShowDeviceTypeModal(default, FormModeEnum.Create);
    }

    public async Task ApplySearch(string searchQuery)
    {
        deviceTypeFilter.CommonSearchText = searchQuery;
        currentPage = 0;
        deviceTypes = await deviceTypeService.GetDeviceTypesAsync(0, deviceTypeFilter);
        StateHasChanged();
        await table.grid.RefreshDataAsync();
    }

    #endregion
}
