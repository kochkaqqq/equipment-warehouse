﻿
@typeparam TItem 

<Modal @ref=@modal IsVerticallyCentered=true Size="ModalSize.Small" />

<TextInput class="form-control" @bind-Value="textinputValue" readonly @onclick=@OnTextInputClick />

@code {
    [Parameter]
    public IEnumerable<TItem> Items { get; set; } = new List<TItem>();
    [Parameter]
    public Func<TItem, string> DisplayItem { get; set; }
    [Parameter]
    public Func<TItem, Guid> GetItemId { get; set; }
    [Parameter]
    public EventCallback<Guid> OnItemSelect { get; set; }
    [Parameter]
    public string Header { get; set; } = "Выберите";
    [Parameter]
    public bool Disabled { get; set; } = false;
    [Parameter]
    public Guid? SelectedItemId { get; set; }
    [Parameter]
    public bool IsMultiply { get; set; } = false;
    [Parameter]
    public List<Guid> SelectedItemsIds { get; set; } = new();
    [Parameter]
    public bool IsShowNewEntityButton { get; set; } = false;
    [Parameter]
    public EventCallback<string> OnNewEntityButtonClick { get; set; }

    private Modal modal = default!;

    private string textinputValue = "Выбрать...";

    private List<SelectionItem> allSelectionItems = new();

    private List<SelectionItem> selectedItems = new();

    protected override void OnParametersSet()
    {
        allSelectionItems = Items.Select(i => new SelectionItem()
        {
            Id = GetItemId(i),
            DisplayName = DisplayItem(i)
        }).ToList();

        if (SelectedItemId != null)
        {
            var item = allSelectionItems.FirstOrDefault(i => i.Id == SelectedItemId);
            if (item != null)
            {
                textinputValue = item.DisplayName;
            }
        }

        base.OnParametersSet();
    }

    private async Task OnTextInputClick()
    {
        if (Disabled)
            return;

        var parameters = new Dictionary<string, object>();
        parameters.Add("Items", allSelectionItems);
        parameters.Add("OnItemSelect", EventCallback.Factory.Create<SelectionItem>(this, SelectItem));
        parameters.Add("IsMultiply", IsMultiply);
        parameters.Add("SelectedItems", selectedItems);
        parameters.Add("OnClearButtonClick", EventCallback.Factory.Create(this, OnClearButtonClick));
        parameters.Add("OnApplyButtonClick", EventCallback.Factory.Create(this, OnApplyButtonClick));
        parameters.Add("IsShowNewEntityButton", IsShowNewEntityButton);
        parameters.Add("OnNewEntityButtonClick", OnNewEntityButtonClick);

        modal.Size = ModalSize.Small;
        await modal.ShowAsync<SelectionContent>(title: Header, parameters: parameters);
    }

    private async Task SelectItem(SelectionItem item)
    {
        if (IsMultiply)
        {
            var alreadySelectedItem = selectedItems.FirstOrDefault(i => i.Id == item.Id);
            if (alreadySelectedItem != null)
            {
                selectedItems.Remove(alreadySelectedItem);
            }
            else
            {
                selectedItems.Add(item);
            }
            textinputValue = string.Join(", ", selectedItems.Select(i => i.DisplayName));
            await OnItemSelect.InvokeAsync(item.Id);
            return;
        }

        textinputValue = item.DisplayName;
        await OnItemSelect.InvokeAsync(item.Id);
        await modal.HideAsync();
    }

    private void OnClearButtonClick()
    {

    }

    private async Task OnApplyButtonClick()
    {
        await modal.HideAsync();
    }

    public void ResetValue()
    {
        selectedItems = new();
        SelectedItemsIds = new();
        textinputValue = "Выбрать...";
    }

    public async Task UpdateData()
    {
        allSelectionItems = Items.Select(i => new SelectionItem()
        {
            Id = GetItemId(i),
            DisplayName = DisplayItem(i)
        }).ToList();
        await OnTextInputClick();
    }
}
